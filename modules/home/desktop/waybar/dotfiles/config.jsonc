{
        "layer": "top",
        "position": "top",
        "spacing": 0,
        "height": 40,
        "margin-top": 6,
        "margin-left": 12,
        "margin-right": 12,
        "reload_style_on_change": true,
        "modules-left": ["custom/clipboard", "clock", "custom/notification"],
        "modules-center": ["hyprland/workspaces"],
        "modules-right": ["group/controls", "group/connectivity", "battery", "tray"],

        "hyprland/workspaces": {
            "format": "{name}",
            "on-click": "activate",
            "sort-by-number": true,
            "on-scroll-up": "hyprctl dispatch workspace e+1",
            "on-scroll-down": "hyprctl dispatch workspace e-1",
            "persistent-workspaces": {
                "*": [ 1, 2, 3, 4, 5 ]
            }
        },
        "custom/clipboard": {
            "format": "",
            "tooltip-format": "Clipboard history",
            "on-click": "cliphist list | rofi -dmenu | cliphist decode | wl-copy",
            "on-click-right": "cliphist wipe"
        },
        "custom/notification": {
            "tooltip": false,
            "format": "{icon}",
            "format-icons": {
                "notification": "َ°‚ڑ",
                "none": "َ°‚œ",
                "dnd-notification": "َ°‚›",
                "dnd-none": "َ°ھ‘",
                "inhibited-notification": "َ°‚ڑ",
                "inhibited-none": "َ°‚œ",
                "dnd-inhibited-notification": "َ°‚›",
                "dnd-inhibited-none": "َ°ھ‘"
            },
            "return-type": "json",
            "exec": "swaync-client -swb",
            "on-click": "swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true
        },
        "clock": {
            "format": "  {:%I:%M %p}",
            "format-alt": "  {:%a %d %b}",
            "interval": 1,
            "tooltip-format": "<tt>{calendar}</tt>",
            "calendar": {
                "mode"          : "month",
                "mode-mon-col"  : 3,
                "on-scroll"     : 1,
                "format": {
                    "months":     "<span color='#ffead3'><b>{}</b></span>",
                    "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                    "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                    "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                    "today":      "<span color='#fAfBfC'><b><u>{}</u></b></span>"
                }
            },
            "actions": {
                "on-click-right": "shift_down",
                "on-click": "mode"
            }
        },
        "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "َ°‚±  {volume}%",
        "format-muted": "َ°–پ  Muted",
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "ignored-sinks": ["Easy Effects Sink"],
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "َ°‹ژ",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
            },
        "tooltip-format": "Volume: {volume}%"
        },
        "backlight": {
            "device": "nvidia_wmi_ec_backlight",
            "format": "{icon}  {percent}%",
            "on-scroll-up": "brightnessctl set 5%+",
            "on-scroll-down": "brightnessctl set 5%-",
            "tooltip-format": "Brightness: {percent}%",
            "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "]
        },
        "network": {
            "interval": 5,
            "format-wifi": "  {essid}",
            "format-ethernet": "َ°ˆ€  Wired",
            "format-disconnected": "َ°–ھ  Offline",
            "format-linked": "َ°–©  {ifname} (No IP)",
            "max-length": 24,
            "tooltip-format-wifi": "{essid}  ({signalStrength}%)\n{ipaddr}\n{frequency} GHz",
            "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
            "tooltip-format-disconnected": "Disconnected",
            "on-click": "kitty nmtui"
        },
        "bluetooth": {
            "format-on": "َ°‚¯",
            "format-off": "َ°‚²",
            "format-disabled": "َ°‚²",
            "format-connected": "َ°‚±  {num_connections}",
            "format-connected-battery": "َ°‚±  {device_battery_percentage}%",
            "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
            "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
            "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
            "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
            "on-click-right": "overskride"
        },
        "battery": {
            "interval":30,
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{icon}  {capacity}%",
            "format-charging": "َ°‚„  {capacity}%",
            "format-plugged": "َ°‚„  {capacity}%",
            "format-alt": "{icon}  {time}",
            "format-icons": [
                "َ°پ»",
                "َ°پ¼",
                "َ°پ¾",
                "َ°‚€",
                "َ°‚‚",
                "َ°پ¹"
            ],
            "tooltip-format": "{capacity}%  â€¢  {timeTo}"
        },
        "group/controls": {
            "orientation": "horizontal",
            "modules": ["backlight", "pulseaudio"]
        },
        "group/connectivity": {
            "orientation": "horizontal",
            "modules": ["network", "bluetooth"]
        },
        "tray": {
            "icon-size": 16,
            "spacing": 10
        }
}
